{
  "manifest_version": 3,
  "name": "YouTube Playlist Progress Tracker",
  "version": "1.0",
  "description": "Add checkboxes to YouTube playlists",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/playlist*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}